  // 5. Bloquear seleção de texto (anti-copy source)
  document.addEventListener('selectstart', e=>e.preventDefault());

  // ---- SECURITY ALERT UI ----
  function showSecAlert(msg){
    let el = document.getElementById('_secAlert');
