      el = document.createElement('div');
      el.id = '_secAlert';
      el.style.cssText='position:fixed;top:20px;left:50%;transform:translateX(-50%);z-index:99999;background:#1a0000;border:2px solid #ff3333;border-radius:8px;padding:14px 24px;color:#ff6b6b;font-family:"Press Start 2P",cursive;font-size:0.55rem;text-align:center;max-width:340px;line-height:1.8;box-shadow:0 0 30px rgba(255,0,0,0.3);';
      document.body.appendChild(el);
    }
    el.textContent = msg;
    el.style.display = 'block';
    clearTimeout(el._t);
    el._t = setTimeout(()=>{ el.style.display='none'; }, 3000);
  }

  // =========================================================
  // STATE
  // =========================================================
  emailjs.init("rh02YfBqLHu1NhcaC");

  let _isAdmin = false;
  let _totalArrecadado = 0;
  let _supporters = [];
  let _adminCode = null;
  let _adminCodeExpiry = 0;
  let _loginAttempts = 0;
  let _lockUntil = 0;
  let _selectedMethod = 'pix';
  const CODE_TTL = 5 * 60 * 1000; // 5 min
  const MAX_ATTEMPTS = 5;
  const LOCKOUT_MS = 15 * 60 * 1000; // 15 min

  function _forceLogout(reason){
    _isAdmin = false;
    document.getElementById('navSacar').style.display = 'none';
    closeOverlay('overlayAdminPanel');
    closeOverlay('overlaySacar');
    setTimeout(()=>showSecAlert(reason||'Sessão encerrada.'), 100);
  }

  // Admin guard: only call fn if admin session active
  function adminGuard(fn){
    if(!_isAdmin){ showSecAlert('🔒 Acesso negado. Faça login como Admin.'); return; }
    fn();
  }

  // ---- Title animation ----
  const titleText = "HOUSE ST";
  const titleEl = document.getElementById('mainTitle');
  titleText.split('').forEach((char, i) => {
    const span = document.createElement('span');
    span.className = 'letter';
    span.textContent = char === ' ' ? '\u00A0' : char;
    span.style.animationDelay = `${i * 0.15}s`;
    titleEl.appendChild(span);
  });

  // ---- Overlay ----
  function openOverlay(id){
    // Guard protected overlays
    if((id==='overlaySacar'||id==='overlayAdminPanel') && !_isAdmin){
      showSecAlert('🔒 Acesso restrito a administradores.');
      return;
    }
    document.getElementById(id).classList.add('active');
    document.body.style.overflow = 'hidden';
    if(id==='overlaySacar'||id==='overlayAdminPanel') updateTotals();
  }
  function closeOverlay(id){
    const el = document.getElementById(id);
    if(el) el.classList.remove('active');
    document.body.style.overflow = '';
  }
  document.querySelectorAll('.overlay').forEach(el=>{
    el.addEventListener('click', e=>{ if(e.target===el) closeOverlay(el.id); });
  });

  // ---- Totals ----
  function updateTotals(){
    const fmt = v=>'R$ '+v.toFixed(2).replace('.',',');
    const ta = document.getElementById('totalAmount');
    if(ta) ta.textContent = fmt(_totalArrecadado);
    const at = document.getElementById('adminTotal');
    if(at) at.textContent = fmt(_totalArrecadado);
    const list = document.getElementById('supporterList');
    if(list){
      if(_supporters.length===0){
        list.innerHTML='<p style="color:#555;font-size:0.65rem;">Nenhum suportador ainda.</p>';
      } else {
        list.innerHTML = _supporters.map(s=>
          `<div style="background:rgba(255,215,0,0.05);border:1px solid rgba(255,215,0,0.15);border-radius:6px;padding:10px 14px;margin-bottom:8px;font-size:0.6rem;">
            <strong style="color:#fff;">${_escape(s.name)}</strong>
            <span style="color:#888;margin-left:8px;">${_escape(s.email)}</span>
            <span style="float:right;color:var(--yellow);font-weight:700;">R$ 3,00</span>
            <div style="color:#666;margin-top:4px;">👤 ${_escape(s.user)} · 💳 ${_escape(s.method)}</div>
          </div>`
        ).join('');
      }
    }
  }
  function _escape(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  // =========================================================
  // PIX QR CODE - Padrão Banco Central EMV
  // =========================================================
  const PIX_KEY = 'victor.vasconcelos.f.92@gmail.com';
  const PIX_NAME = 'House ST';
  const PIX_CITY = 'BRASIL';
  const PIX_VALUE = '3.00';

  function _crc16(str) {
    let crc = 0xFFFF;
    for (let i = 0; i < str.length; i++) {
      crc ^= str.charCodeAt(i) << 8;
      for (let j = 0; j < 8; j++) {
        if (crc & 0x8000) crc = (crc << 1) ^ 0x1021;
        else crc <<= 1;
        crc &= 0xFFFF;
      }
    }
    return crc.toString(16).toUpperCase().padStart(4, '0');
  }

  function _tlv(id, value) {
    return id + value.length.toString().padStart(2, '0') + value;
  }

  // Gera txid único por sessão (não reutilizável)
  function _gerarTxid() {
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
    let id = 'HST';
    for (let i = 0; i < 10; i++) id += chars[Math.floor(Math.random() * chars.length)];
    return id;
  }

  function gerarPixPayload() {
    const gui = _tlv('00', 'BR.GOV.BCB.PIX') + _tlv('01', PIX_KEY);
    const merchantInfo = _tlv('26', gui);
    const txid = _tlv('05', _gerarTxid());
    const addInfo = _tlv('50', _tlv('01', 'SUPORTADOR HOUSEST') + txid);
    const payload =
      _tlv('00', '01') +
      merchantInfo +
      _tlv('52', '0000') +
      _tlv('53', '986') +
      _tlv('54', PIX_VALUE) +
      _tlv('58', 'BR') +
      _tlv('59', PIX_NAME.substring(0, 25)) +
      _tlv('60', PIX_CITY) +
      addInfo +
      '6304';
    return payload + _crc16(payload);
  }

  let _pixPayload = '';
  let _qrInstance = null;
  let _qrExpiry = 0;
  let _qrTimerInterval = null;
  const QR_TTL = 10 * 60; // 10 minutos em segundos

  // Rate limit: máx 3 gerações de QR por sessão
  let _qrGenCount = 0;
  const QR_MAX_GEN = 3;

  function _iniciarTimerQR() {
    clearInterval(_qrTimerInterval);
    _qrExpiry = QR_TTL;
    const timerEl = document.getElementById('qrTimer');
    const qrBox = document.getElementById('qrcode');
    const copyBtn = document.getElementById('btnCopiar');

    _qrTimerInterval = setInterval(() => {
      _qrExpiry--;
      if (timerEl) {
        const m = String(Math.floor(_qrExpiry / 60)).padStart(2, '0');
        const s = String(_qrExpiry % 60).padStart(2, '0');
        timerEl.textContent = `⏱ Expira em ${m}:${s}`;
        // Amarelo → laranja → vermelho conforme expira
        if (_qrExpiry > 120) timerEl.style.color = '#aaa';
        else if (_qrExpiry > 30) timerEl.style.color = '#FFA500';
        else timerEl.style.color = '#ff4444';
      }
      if (_qrExpiry <= 0) {
        clearInterval(_qrTimerInterval);
        // Invalidar QR
        _pixPayload = '';
        if (qrBox) qrBox.innerHTML = '<div style="color:#ff4444;font-size:0.6rem;text-align:center;padding:10px;font-family:\'Press Start 2P\',cursive;line-height:2;">QR CODE<br>EXPIRADO</div>';
        if (copyBtn) { copyBtn.disabled = true; copyBtn.style.opacity = '0.4'; }
        document.getElementById('pixCodigoDisplay').textContent = '— expirado —';
        if (timerEl) timerEl.textContent = '⏱ Expirado';
      }
    }, 1000);
  }

  function gerarQRCode() {
    if (_qrGenCount >= QR_MAX_GEN) {
      showSecAlert('⚠️ Limite de tentativas atingido. Recarregue a página.');
      return;
    }
    _qrGenCount++;

    _pixPayload = gerarPixPayload();
    document.getElementById('pixCodigoDisplay').textContent = _pixPayload;

    const qrDiv = document.getElementById('qrcode');
    qrDiv.innerHTML = '';

    // Re-habilitar botão copiar caso estava desabilitado
    const copyBtn = document.getElementById('btnCopiar');
    if (copyBtn) { copyBtn.disabled = false; copyBtn.style.opacity = '1'; }

    _qrInstance = new QRCode(qrDiv, {
      text: _pixPayload,
      width: 180,
      height: 180,
      colorDark: '#000000',
      colorLight: '#ffffff',
      correctLevel: QRCode.CorrectLevel.H  // Máxima correção de erro
    });

    _iniciarTimerQR();
  }

  function copiarPix() {
    if (!_pixPayload) { showSecAlert('⚠️ QR Code expirado! Volte e tente novamente.'); return; }
    if (_qrExpiry <= 0) { showSecAlert('⚠️ Código expirado! Volte e gere um novo.'); return; }
    navigator.clipboard.writeText(_pixPayload).then(() => {
      const btn = document.getElementById('btnCopiar');
      btn.textContent = '✅ COPIADO!';
      btn.style.background = 'linear-gradient(135deg,#4dff88,#00cc55)';
      setTimeout(() => {
        btn.textContent = '📋 COPIAR';
        btn.style.background = 'linear-gradient(135deg,#FFD700,#FFA500)';
      }, 2500);
    }).catch(() => {
      const ta = document.createElement('textarea');
      ta.value = _pixPayload;
      ta.style.position = 'fixed'; ta.style.opacity = '0';
      document.body.appendChild(ta); ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      const btn = document.getElementById('btnCopiar');
      btn.textContent = '✅ COPIADO!';
      setTimeout(() => { btn.textContent = '📋 COPIAR'; }, 2500);
    });
  }

  function irParaPagamento() {
    document.getElementById('stepPlano').style.display = 'none';
    document.getElementById('stepPix').style.display = 'block';
    document.getElementById('stepSucesso').style.display = 'none';
    setTimeout(gerarQRCode, 100);
  }

  function voltarPlano() {
    clearInterval(_qrTimerInterval);
    document.getElementById('stepPlano').style.display = 'block';
    document.getElementById('stepPix').style.display = 'none';
    document.getElementById('stepSucesso').style.display = 'none';
  }

  function confirmarPagamento() {
    const name = document.getElementById('supporterName').value.trim();
    const user = document.getElementById('supporterUser').value.trim();
    _supporters.push({ name, user, method: 'pix' });
    _totalArrecadado += 3;
    updateTotals();
    clearInterval(_qrTimerInterval);
    document.getElementById('stepPlano').style.display = 'none';
    document.getElementById('stepPix').style.display = 'none';
    document.getElementById('stepSucesso').style.display = 'block';
  }

  function resetSupporter() {
    clearInterval(_qrTimerInterval);
    document.getElementById('supporterName').value = '';
    document.getElementById('supporterUser').value = '';
    document.getElementById('stepPlano').style.display = 'block';
    document.getElementById('stepPix').style.display = 'none';
    document.getElementById('stepSucesso').style.display = 'none';
    _pixPayload = '';
    _qrInstance = null;
    _qrExpiry = 0;
    _qrGenCount = 0;
  }

  // ---- Sacar (ADMIN ONLY) ----
  function enviarPix(){
    if(!_isAdmin){ _forceLogout('🚨 Acesso não autorizado!'); return; }
    if(_devOpen){ _forceLogout('🚨 DevTools detectado!'); return; }
    const key = document.getElementById('pixKey').value.trim();
    const amount = parseFloat(document.getElementById('pixAmount').value);
    if(!key){ showSecAlert('Digite uma chave PIX!'); return; }
    if(!amount||amount<=0){ showSecAlert('Digite um valor válido!'); return; }
    if(amount>_totalArrecadado){ showSecAlert('Saldo insuficiente!'); return; }
    _totalArrecadado -= amount;
    document.getElementById('pixSuccess').style.display='block';
    document.getElementById('pixKey').value='';
    document.getElementById('pixAmount').value='';
    updateTotals();
    setTimeout(()=>document.getElementById('pixSuccess').style.display='none',3000);
  }

  // ---- Admin Login com rate-limit e código criptografado ----
  async function enviarCodigoAdmin(){
    const now = Date.now();
    if(now < _lockUntil){
      const mins = Math.ceil((_lockUntil-now)/60000);
      showSecAlert(`🔒 Bloqueado! Tente em ${mins} min.`);
      return;
    }
    const btn = document.getElementById('btnEnviarCodigo');
    btn.textContent='Enviando...'; btn.disabled=true;

    // Gerar código e salvar como hash XOR simples (não exposto no console)
    const raw = Math.floor(100000+Math.random()*900000).toString();
    const key2 = Math.floor(Math.random()*9)+1;
    // Store only XOR-scrambled version in memory, never the plain code
    _adminCode = { scrambled: raw.split('').map(c=>(parseInt(c)^key2).toString()).join(''), key2 };
    _adminCodeExpiry = now + CODE_TTL;

    try {
      await emailjs.send("service_housest","template_admincode",{
        to_email:"levibonitao1234@gmail.com",
        code: raw
      });
    } catch(e){ /* silent */ }

    document.getElementById('adminCodeSent').style.display='block';
    document.getElementById('adminCodeSection').style.display='block';
    btn.textContent='Reenviar Código'; btn.disabled=false;

    // Auto-expire code
    setTimeout(()=>{ _adminCode=null; }, CODE_TTL);
  }

  function verificarCodigo(){
    const now = Date.now();
    if(now < _lockUntil){
      const mins = Math.ceil((_lockUntil-now)/60000);
      showSecAlert(`🔒 Muitas tentativas! Aguarde ${mins} min.`);
      return;
    }
    if(!_adminCode||now>_adminCodeExpiry){
      document.getElementById('adminError').style.display='block';
      document.getElementById('adminError').textContent='❌ Código expirado. Solicite um novo.';
      _adminCode=null;
      return;
    }
    const input = document.getElementById('adminCodeInput').value.trim();
    // Reconstruct plain code from scrambled to compare
    const plain = _adminCode.scrambled.split('').map(c=>(parseInt(c)^_adminCode.key2).toString()).join('');

    document.getElementById('adminError').style.display='none';
    if(input===plain){
      _isAdmin = true;
      _loginAttempts = 0;
      _adminCode = null;
      // Reveal Sacar in nav
      document.getElementById('navSacar').style.display='inline';
      closeOverlay('overlayAdminLogin');
      openOverlay('overlayAdminPanel');
      document.getElementById('adminCodeInput').value='';
      document.getElementById('adminCodeSection').style.display='none';
      document.getElementById('adminCodeSent').style.display='none';
      // Auto-logout after 30 min inactivity
      resetAutoLogout();
    } else {
      _loginAttempts++;
      if(_loginAttempts>=MAX_ATTEMPTS){
        _lockUntil = Date.now()+LOCKOUT_MS;
        _adminCode = null;
        document.getElementById('adminError').style.display='block';
        document.getElementById('adminError').textContent=`🔒 ${MAX_ATTEMPTS} tentativas erradas. Bloqueado por 15 min.`;
      } else {
        document.getElementById('adminError').style.display='block';
        document.getElementById('adminError').textContent=`❌ Código inválido. (${MAX_ATTEMPTS-_loginAttempts} tentativas restantes)`;
      }
    }
  }

  // ---- Auto logout ----
  let _autoLogoutTimer;
  function resetAutoLogout(){
    clearTimeout(_autoLogoutTimer);
    _autoLogoutTimer = setTimeout(()=>{
      if(_isAdmin) _forceLogout('⏰ Sessão expirada por inatividade.');
    }, 30*60*1000);
  }
  ['click','keydown','mousemove'].forEach(ev=>document.addEventListener(ev,()=>{ if(_isAdmin) resetAutoLogout(); }));

  // ---- Logout ----
  function adminLogout(){
    _forceLogout('👋 Logout realizado com sucesso.');
  }

  // ---- Salvar Plano ----
  function salvarPlano(){
    if(!_isAdmin){ showSecAlert('🔒 Sem permissão.'); return; }
    document.getElementById('planSaved').style.display='block';
    setTimeout(()=>document.getElementById('planSaved').style.display='none',2500);
  }

  // Expose only needed functions globally (minimum surface)
  window.openOverlay = openOverlay;
  window.closeOverlay = closeOverlay;
  window.irParaPagamento = irParaPagamento;
  window.voltarPlano = voltarPlano;
  window.confirmarPagamento = confirmarPagamento;
  window.resetSupporter = resetSupporter;
  window.copiarPix = copiarPix;
  window.enviarPix = enviarPix;
  window.enviarCodigoAdmin = enviarCodigoAdmin;
  window.verificarCodigo = verificarCodigo;
  window.salvarPlano = salvarPlano;
  window.adminLogout = adminLogout;
  window.adminGuard = adminGuard;

})();
</script>
</body>
</html>
