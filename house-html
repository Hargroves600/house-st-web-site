<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HOUSE ST</title>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Rajdhani:wght@600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --yellow: #FFD700;
    --yellow2: #FFA500;
    --dark: #0a0a0a;
    --dark2: #111111;
    --dark3: #1a1a1a;
    --card: #161616;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    background: var(--dark);
    color: #fff;
    font-family: 'Rajdhani', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* BG particles */
  body::before {
    content:'';
    position:fixed;
    inset:0;
    background: 
      radial-gradient(ellipse at 20% 50%, rgba(255,215,0,0.05) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(255,165,0,0.04) 0%, transparent 50%);
    pointer-events:none;
    z-index:0;
  }

  /* NAV */
  nav {
    position: fixed;
    top:0; left:0; right:0;
    z-index:100;
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding: 14px 40px;
    background: rgba(10,10,10,0.95);
    border-bottom: 2px solid rgba(255,215,0,0.15);
    backdrop-filter: blur(10px);
  }
  .nav-logo {
    font-family: 'Press Start 2P', cursive;
    font-size: 1rem;
    letter-spacing: 2px;
    background: linear-gradient(90deg, #FFD700, #FFA500, #FFD700);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shine 2s linear infinite;
  }
  @keyframes shine {
    to { background-position: 200% center; }
  }
  .nav-links { display:flex; gap:20px; align-items:center; }
  .nav-links a {
    color: #ccc;
    text-decoration:none;
    font-size:0.7rem;
    font-weight:600;
    letter-spacing:1px;
    text-transform:uppercase;
    transition: color 0.2s;
    cursor:pointer;
  }
  .nav-links a:hover { color: var(--yellow); }
  .nav-btn-admin {
    background: transparent;
    border: 1.5px solid rgba(255,215,0,0.4);
    color: var(--yellow);
    padding: 6px 18px;
    border-radius: 4px;
    font-family: 'Rajdhani', sans-serif;
    font-weight:700;
    font-size:0.9rem;
    letter-spacing:1px;
    cursor:pointer;
    transition: all 0.2s;
  }
  .nav-btn-admin:hover {
    background: rgba(255,215,0,0.1);
    border-color: var(--yellow);
  }

  /* HERO */
  .hero {
    position:relative;
    min-height:100vh;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    text-align:center;
    padding: 100px 20px 60px;
    z-index:1;
  }
  .hero-title {
    font-family: 'Press Start 2P', cursive;
    font-size: clamp(1.8rem, 6vw, 4.5rem);
    letter-spacing: 4px;
    line-height:1.3;
    position:relative;
    animation: titleReveal 0.8s cubic-bezier(0.16,1,0.3,1) both;
  }
  @keyframes titleReveal {
    from { opacity:0; transform:translateY(-40px) scale(0.9); }
    to { opacity:1; transform:translateY(0) scale(1); }
  }
  .hero-title .letter {
    display:inline-block;
    background: linear-gradient(180deg, #FFE566 0%, #FFD700 40%, #FFA500 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: letterFloat 3s ease-in-out infinite;
    text-shadow: none;
    filter: drop-shadow(0 0 20px rgba(255,215,0,0.5));
  }
  .hero-title .letter:nth-child(1) { animation-delay: 0s; }
  .hero-title .letter:nth-child(2) { animation-delay: 0.15s; }
  .hero-title .letter:nth-child(3) { animation-delay: 0.3s; }
  .hero-title .letter:nth-child(4) { animation-delay: 0.45s; }
  .hero-title .letter:nth-child(5) { animation-delay: 0.6s; }
  .hero-title .letter:nth-child(6) { animation-delay: 0.75s; }
  .hero-title .letter:nth-child(7) { animation-delay: 0.9s; }
  .hero-title .letter:nth-child(8) { animation-delay: 1.05s; }
  @keyframes letterFloat {
    0%,100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  .hero-subtitle {
    font-family:'Orbitron', sans-serif;
    font-size: clamp(0.4rem, 1.2vw, 0.6rem);
    letter-spacing: 4px;
    color: rgba(255,215,0,0.5);
    margin-top: 10px;
    text-transform:uppercase;
    animation: fadeUp 0.8s 0.3s both;
  }
  @keyframes fadeUp {
    from { opacity:0; transform:translateY(20px); }
    to { opacity:1; transform:translateY(0); }
  }
  .hero-desc {
    font-size:0.75rem;
    color:#aaa;
    margin-top:20px;
    max-width:500px;
    animation: fadeUp 0.8s 0.5s both;
  }
  .hero-buttons {
    display:flex;
    gap:16px;
    margin-top:40px;
    flex-wrap:wrap;
    justify-content:center;
    animation: fadeUp 0.8s 0.7s both;
  }
  .btn-primary {
    background: linear-gradient(135deg, #FFD700, #FFA500);
    color: #000;
    border:none;
    padding: 14px 36px;
    font-family:'Rajdhani',sans-serif;
    font-size:0.75rem;
    font-weight:700;
    letter-spacing:2px;
    text-transform:uppercase;
    border-radius:6px;
    cursor:pointer;
    position:relative;
    overflow:hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 0 20px rgba(255,215,0,0.3);
  }
  .btn-primary::before {
    content:'';
    position:absolute;
    top:0; left:-100%;
    width:100%; height:100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    transition:0.4s;
  }
  .btn-primary:hover::before { left:100%; }
  .btn-primary:hover {
    transform:translateY(-2px);
    box-shadow: 0 0 35px rgba(255,215,0,0.5);
  }
  .btn-secondary {
    background: transparent;
    color: var(--yellow);
    border: 2px solid var(--yellow);
    padding: 12px 32px;
    font-family:'Rajdhani',sans-serif;
    font-size:0.75rem;
    font-weight:700;
    letter-spacing:2px;
    text-transform:uppercase;
    border-radius:6px;
    cursor:pointer;
    transition: all 0.2s;
  }
  .btn-secondary:hover {
    background: rgba(255,215,0,0.1);
    transform:translateY(-2px);
    box-shadow: 0 0 20px rgba(255,215,0,0.2);
  }

  /* POPUP */
  .overlay {
    display:none;
    position:fixed;
    inset:0;
    background: rgba(0,0,0,0.85);
    z-index:200;
    align-items:center;
    justify-content:center;
    backdrop-filter: blur(4px);
  }
  .overlay.active { display:flex; }
  .popup {
    background: var(--card);
    border: 2px solid rgba(255,215,0,0.3);
    border-radius:12px;
    padding:40px;
    max-width:500px;
    width:90%;
    position:relative;
    animation: popIn 0.3s cubic-bezier(0.16,1,0.3,1);
  }
  @keyframes popIn {
    from { opacity:0; transform:scale(0.8); }
    to { opacity:1; transform:scale(1); }
  }
  .popup-close {
    position:absolute;
    top:14px; right:18px;
    background:none; border:none;
    color:#888; font-size:1.5rem;
    cursor:pointer;
    transition:color 0.2s;
  }
  .popup-close:hover { color:#fff; }
  .popup h2 {
    font-family:'Press Start 2P',cursive;
    font-size:0.9rem;
    letter-spacing:3px;
    color:var(--yellow);
    margin-bottom:10px;
  }
  .popup p { color:#ccc; font-size:1rem; line-height:1.6; margin-bottom:10px; }
  .popup .tiktok-handle {
    font-family:'Press Start 2P',cursive;
    font-size:0.75rem;
    color:var(--yellow);
    font-weight:700;
    background: rgba(255,215,0,0.08);
    padding:10px 16px;
    border-radius:6px;
    border:1px solid rgba(255,215,0,0.2);
    display:inline-block;
    margin:10px 0;
  }

  /* REQUISITOS */
  .req-section {
    margin-top:30px;
    border-top:1px solid rgba(255,215,0,0.15);
    padding-top:24px;
  }
  .req-section h3 {
    font-family:'Press Start 2P',cursive;
    font-size:0.75rem;
    letter-spacing:3px;
    color:#fff;
    margin-bottom:16px;
  }
  .req-cards {
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:10px;
  }
  .req-card {
    background: rgba(255,215,0,0.05);
    border:1px solid rgba(255,215,0,0.2);
    border-radius:8px;
    padding:14px 16px;
    display:flex;
    align-items:center;
    gap:10px;
  }
  .req-card .icon {
    font-size:1.4rem;
    flex-shrink:0;
  }
  .req-card span {
    font-size:0.9rem;
    font-weight:600;
    color:#ddd;
    letter-spacing:0.5px;
  }

  /* SUPPORTER POPUP */
  .plan-card {
    background: linear-gradient(135deg, rgba(255,215,0,0.08), rgba(255,165,0,0.05));
    border:2px solid var(--yellow);
    border-radius:12px;
    padding:30px;
    text-align:center;
    margin:20px 0;
  }
  .plan-card h3 {
    font-family:'Press Start 2P',cursive;
    font-size:0.9rem;
    letter-spacing:3px;
    color:var(--yellow);
    margin-bottom:8px;
  }
  .plan-price {
    font-family:'Press Start 2P',cursive;
    font-size:1.4rem;
    font-weight:900;
    color:#fff;
    margin:10px 0;
  }
  .plan-price span { font-size:1rem; color:#aaa; font-weight:400; }
  .plan-perks { list-style:none; color:#ccc; font-size:0.7rem; margin:16px 0; }
  .plan-perks li { padding:4px 0; }
  .plan-perks li::before { content:'✦ '; color:var(--yellow); }
  .pix-input {
    width:100%;
    background: rgba(255,255,255,0.05);
    border:1px solid rgba(255,215,0,0.3);
    border-radius:6px;
    padding:12px 16px;
    color:#fff;
    font-family:'Rajdhani',sans-serif;
    font-size:1rem;
    margin:8px 0;
    outline:none;
    transition:border-color 0.2s;
  }
  .pix-input:focus { border-color:var(--yellow); }
  .pix-input::placeholder { color:#555; }

  /* SACAR SECTION */
  .sacar-total {
    background: rgba(255,215,0,0.07);
    border:1px solid rgba(255,215,0,0.25);
    border-radius:8px;
    padding:20px;
    text-align:center;
    margin:16px 0;
  }
  .sacar-total p { color:#aaa; font-size:0.9rem; margin-bottom:4px; }
  .sacar-total .amount {
    font-family:'Press Start 2P',cursive;
    font-size:1rem;
    font-weight:700;
    color:var(--yellow);
  }
  .success-msg {
    background: rgba(0,200,80,0.1);
    border:1px solid rgba(0,200,80,0.3);
    border-radius:6px;
    padding:12px;
    color:#4dff8a;
    font-size:0.9rem;
    margin-top:10px;
    display:none;
  }

  /* ADMIN */
  .admin-form label {
    display:block;
    color:#aaa;
    font-size:0.85rem;
    margin-bottom:4px;
    margin-top:14px;
    letter-spacing:1px;
    text-transform:uppercase;
  }
  .admin-section-title {
    font-family:'Press Start 2P',cursive;
    font-size:0.7rem;
    letter-spacing:2px;
    color:var(--yellow);
    margin-top:24px;
    margin-bottom:8px;
    border-bottom:1px solid rgba(255,215,0,0.15);
    padding-bottom:8px;
  }

  /* SCROLL sections */
  .section {
    position:relative;
    z-index:1;
    padding: 80px 40px;
    max-width:1200px;
    margin:0 auto;
  }
  .section-title {
    font-family:'Press Start 2P',cursive;
    font-size:1.2rem;
    letter-spacing:5px;
    color:var(--yellow);
    margin-bottom:40px;
    text-align:center;
  }

  /* FOOTER */
  footer {
    position:relative;
    z-index:1;
    text-align:center;
    padding:30px;
    border-top:1px solid rgba(255,215,0,0.1);
    color:#444;
    font-size:0.85rem;
    letter-spacing:2px;
    text-transform:uppercase;
  }
  footer span { color:rgba(255,215,0,0.3); }

  /* glitch decoration */
  .glow-line {
    width:80px;
    height:3px;
    background: linear-gradient(90deg, transparent, var(--yellow), transparent);
    margin: 16px auto;
    border-radius:2px;
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width:6px; }
  ::-webkit-scrollbar-track { background:#0a0a0a; }
  ::-webkit-scrollbar-thumb { background:rgba(255,215,0,0.3); border-radius:3px; }

  /* PAY METHODS */
  .pay-method {
    background: rgba(255,255,255,0.04);
    border: 1.5px solid rgba(255,255,255,0.1);
    border-radius:8px;
    padding:12px 10px;
    display:flex;
    align-items:center;
    gap:8px;
    cursor:pointer;
    transition: all 0.2s;
    font-size:0.65rem;
    font-family:'Rajdhani',sans-serif;
    font-weight:700;
    color:#aaa;
  }
  .pay-method:hover { border-color:rgba(255,215,0,0.4); color:#fff; }
  .pay-method.active {
    border-color: var(--yellow);
    background: rgba(255,215,0,0.08);
    color: var(--yellow);
  }
  .pay-icon { font-size:1.1rem; }

  @media(max-width:600px){
    nav { padding:12px 20px; }
    .req-cards { grid-template-columns:1fr; }
    .hero-buttons { flex-direction:column; align-items:center; }
    .popup { padding:28px 20px; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">HOUSE ST</div>
  <div class="nav-links">
    <a onclick="openOverlay('overlaySupporter')">Suportador</a>
    <a id="navSacar" style="display:none;" onclick="openOverlay('overlaySacar')">Sacar</a>
    <button class="nav-btn-admin" onclick="openOverlay('overlayAdminLogin')">Admin</button>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <h1 class="hero-title" id="mainTitle"></h1>
  <div class="hero-subtitle">Comunidade Oficial</div>
  <div class="glow-line"></div>
  <p class="hero-desc">Bem-vindo à House ST — entre, conecte-se e faça parte da nossa família.</p>
  <div class="hero-buttons">
    <button class="btn-primary" onclick="openOverlay('overlayEntrar')">Entre Na House</button>
    <button class="btn-secondary" onclick="openOverlay('overlaySupporter')">Suportador</button>
  </div>
</section>

<footer>
  <p>© 2024 <span>HOUSE ST</span> — Todos os direitos reservados</p>
</footer>

<!-- ===== OVERLAY: ENTRAR ===== -->
<div class="overlay" id="overlayEntrar">
  <div class="popup">
    <button class="popup-close" onclick="closeOverlay('overlayEntrar')">✕</button>
    <h2>🏠 Entre Na House!</h2>
    <div class="glow-line" style="margin:10px 0;"></div>
    <p>Para entrar na nossa comunidade, entre em contato pelo TikTok:</p>
    <div class="tiktok-handle">@holly_wheeler448</div>
    <p style="margin-top:8px; color:#888; font-size:0.9rem;">Mande uma mensagem e aguarde a resposta!</p>

    <div class="req-section">
      <h3>📋 Requisitos</h3>
      <div class="req-cards">
        <div class="req-card">
          <span class="icon">🔞</span>
          <span>Tenha 10+ De Idade!</span>
        </div>
        <div class="req-card">
          <span class="icon">⚡</span>
          <span>Seja Ativo</span>
        </div>
        <div class="req-card">
          <span class="icon">📝</span>
          <span>Preencha a Fichinha!</span>
        </div>
        <div class="req-card">
          <span class="icon">🎉</span>
          <span>Participe dos eventos <em style="color:#666;font-size:0.8rem">(Não Obrigatório)</em></span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ===== OVERLAY: SUPORTADOR ===== -->
<div class="overlay" id="overlaySupporter">
  <div class="popup" style="max-width:480px; padding:0; overflow:hidden; border:none; border-radius:16px;">

    <!-- STEP 1: PLANO -->
    <div id="stepPlano" style="display:block;">
      <!-- Header gradiente -->
      <div style="background:linear-gradient(135deg,#1a1200,#2a1f00); padding:32px 32px 24px; border-bottom:1px solid rgba(255,215,0,0.15); position:relative;">
        <button class="popup-close" onclick="closeOverlay('overlaySupporter')" style="top:16px;right:16px;">✕</button>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">
          <span style="font-size:1.4rem;">⭐</span>
          <span style="font-family:'Press Start 2P',cursive;font-size:0.6rem;color:var(--yellow);letter-spacing:2px;">HOUSE ST</span>
        </div>
        <h2 style="font-family:'Press Start 2P',cursive;font-size:1rem;color:#fff;line-height:1.5;margin-bottom:8px;">Plano Suportador</h2>
        <div style="display:flex;align-items:baseline;gap:6px;">
          <span style="font-family:'Press Start 2P',cursive;font-size:1.6rem;color:var(--yellow);">R$3</span>
          <span style="color:#888;font-size:0.8rem;">,00 / mês</span>
        </div>
        <!-- Badge -->
        <div style="position:absolute;top:20px;right:56px;background:linear-gradient(135deg,#FFD700,#FFA500);color:#000;font-family:'Press Start 2P',cursive;font-size:0.4rem;padding:5px 10px;border-radius:20px;letter-spacing:1px;">POPULAR</div>
      </div>

      <!-- Mensagem única -->
      <div style="padding:24px 32px; background:var(--card);">
        <div style="text-align:center;padding:20px;background:rgba(255,215,0,0.06);border:1px solid rgba(255,215,0,0.2);border-radius:12px;margin-bottom:20px;">
          <span style="font-size:2rem;">❤️</span>
          <p style="font-family:'Press Start 2P',cursive;font-size:0.6rem;color:var(--yellow);line-height:2;margin-top:10px;">Apoie a nossa House!</p>
        </div>

        <!-- Separador -->
        <div style="height:1px;background:rgba(255,255,255,0.06);margin:20px 0;"></div>

        <!-- Campos -->
        <p style="font-family:'Press Start 2P',cursive;font-size:0.5rem;color:#888;letter-spacing:2px;margin-bottom:12px;">SEUS DADOS</p>
        <input class="pix-input" type="text" placeholder="Seu nome (Opcional)" id="supporterName" style="margin-bottom:8px;">
        <input class="pix-input" type="text" placeholder="TikTok (ex: @seuperfil)" id="supporterUser">

        <button class="btn-primary" style="width:100%;margin-top:20px;padding:16px;" onclick="irParaPagamento()">
          Continuar para Pagamento →
        </button>
        <p style="text-align:center;color:#555;font-size:0.7rem;margin-top:10px;">🔒 Pagamento 100% via PIX • Seguro</p>
      </div>
    </div>

    <!-- STEP 2: QR CODE PIX -->
    <div id="stepPix" style="display:none;">
      <div style="background:linear-gradient(135deg,#0a1a0a,#0f2a0f); padding:24px 32px 20px; border-bottom:1px solid rgba(255,215,0,0.15); position:relative;">
        <button class="popup-close" onclick="closeOverlay('overlaySupporter');resetSupporter();" style="top:16px;right:16px;font-size:1rem;">✕</button>
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="font-size:1.2rem;">⚡</span>
          <span style="font-family:'Press Start 2P',cursive;font-size:0.55rem;color:#4dff88;letter-spacing:2px;">PAGAMENTO PIX</span>
        </div>
        <p style="color:#aaa;font-size:0.8rem;margin-top:6px;">Escaneie o QR Code ou copie o código</p>
      </div>

      <div style="padding:28px 32px;background:var(--card);">
        <!-- Valor destaque -->
        <div style="text-align:center;margin-bottom:20px;">
          <div style="font-family:'Press Start 2P',cursive;font-size:1.4rem;color:var(--yellow);">R$ 3,00</div>
          <div style="color:#666;font-size:0.75rem;margin-top:4px;">Plano Suportador — House ST</div>
        </div>

        <!-- QR Code box -->
        <div style="background:#fff;border-radius:12px;padding:16px;width:fit-content;margin:0 auto 10px;box-shadow:0 0 30px rgba(255,215,0,0.2);">
          <div id="qrcode" style="width:180px;height:180px;display:flex;align-items:center;justify-content:center;">
            <div style="color:#333;font-size:0.7rem;text-align:center;">Gerando...</div>
          </div>
        </div>
        <!-- Timer -->
        <div style="text-align:center;margin-bottom:14px;">
          <span id="qrTimer" style="font-family:'Press Start 2P',cursive;font-size:0.5rem;color:#aaa;letter-spacing:1px;">⏱ Carregando...</span>
        </div>

        <!-- Código copia e cola -->
        <div style="margin-bottom:16px;">
          <p style="font-family:'Press Start 2P',cursive;font-size:0.5rem;color:#888;letter-spacing:2px;margin-bottom:8px;">COPIA E COLA PIX</p>
          <div style="display:flex;gap:8px;align-items:stretch;">
            <div id="pixCodigoDisplay" style="flex:1;background:rgba(255,255,255,0.04);border:1px solid rgba(255,215,0,0.2);border-radius:8px;padding:10px 12px;font-size:0.6rem;color:#aaa;word-break:break-all;line-height:1.6;max-height:60px;overflow:hidden;font-family:monospace;">
              Gerando código PIX...
            </div>
